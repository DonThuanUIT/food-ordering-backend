spring:
  datasource:
    url: ${DB_URL:jdbc:postgresql://localhost:5432/neondb}
    username: ${DB_USERNAME:postgres}
    password: ${DB_PASSWORD:your_password}

  data:
    redis:
      url: ${REDIS_URL:redis://localhost:6379}

  mail:
    username: ${SMTP_USERNAME:your_email@gmail.com}
    password: ${SMTP_PASSWORD:your_app_password}

jwt:
  secret: ${JWT_SECRET:GenerateYourOwnSecureRandom32ByteKeyHereForSecurity}

cloudinary:
  cloud-name: ${CLOUDINARY_CLOUD_NAME:your_cloud_name}
  api-key: ${CLOUDINARY_API_KEY:your_api_key}
  api-secret: ${CLOUDINARY_API_SECRET:your_api_secret}

gemini:
  api-key: ${GEMINI_API_KEY:your_gemini_api_key}
